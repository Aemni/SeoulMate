pipeline {
    agent any
    environment {
        COMPOSE_FILE = "server/docker-compose.yml"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build & Deploy') {
            steps {
                sh """
                    cd server
                    docker compose down
                    docker compose up -d --build
                """
            }
        }
        stage('Health Check') {
            steps {
                sh "sleep 5 && curl -f http://localhost:8000/health || exit 1"
            }
        }
    }
    post {
        success { echo "✅ 배포 성공!" }
        failure { echo "❌ 배포 실패 — 로그 확인 필요" }
    }
}