pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build & Deploy') {
            steps {
                sshagent(['seoulmate-ssh']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no overlord@seoulmate.cloud '
                            cd ~/SeoulMate &&
                            git pull origin main &&
                            cd server &&
                            docker-compose down &&
                            docker-compose up -d --build
                        '
                    """
                }
            }
        }
        stage('Health Check') {
            steps {
                sh "sleep 5 && curl -f http://seoulmate.cloud:8000/health || exit 1"
            }
        }
    }
    post {
        success { echo "✅ 배포 성공!" }
        failure { echo "❌ 배포 실패 — 로그 확인 필요" }
    }
}